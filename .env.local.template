# =====================================================
# .env.local — desarrollo local
# Sustituye los valores marcados como REPLACE_ME
# =====================================================

# --- Supabase (REPLACE_ME) ---
NEXT_PUBLIC_SUPABASE_URL=REPLACE_ME_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME_SUPABASE_ANON_KEY

# --- Dominio corporativo (REPLACE_ME) ---
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=empresa.com

# --- IPs de oficina (en local da igual lo que pongas si activas el bypass) ---
ALLOWED_OFFICE_IPS=80.25.10.100,80.25.10.101

# --- Branding ---
NEXT_PUBLIC_APP_NAME=Acerca Clock

# --- Service Role Key (panel admin) ---
# Panel Supabase > Settings > API > service_role secret. NO exponer en cliente.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_SUPABASE_SERVICE_ROLE_KEY

# --- Emails con acceso al panel /admin (RRHH) ---
ADMIN_EMAILS=rrhh@acerca.info

# --- DEV ONLY: bypass de IP. NO funciona en producción (NODE_ENV=production) ---
DEV_BYPASS_IP_CHECK=true
