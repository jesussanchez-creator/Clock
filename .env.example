# =====================================================
# Acerca Clock - variables de entorno
# Copia este fichero a .env.local y rellena los valores
# =====================================================

# --- Supabase ---
# Panel Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Dominio corporativo permitido para login ---
# Sólo se aceptan emails @este-dominio
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=empresa.com

# --- Whitelist de IPs de oficina ---
# Lista separada por comas. Soporta IPs exactas (IPv4 o IPv6)
# y rangos CIDR (p.ej. 80.25.10.0/24).
ALLOWED_OFFICE_IPS=80.25.10.100,80.25.10.101

# --- Branding ---
NEXT_PUBLIC_APP_NAME=Acerca Clock

# --- DEV ONLY: bypass del check de IP para probar en local ---
# IMPORTANTE: sólo se aplica si NODE_ENV !== 'production'.
# En Vercel siempre vale 'production' → este flag NO desactiva nada en prod.
# Quita el comentario en .env.local cuando quieras probar el flujo sin
# añadir tu IP pública a la whitelist.
# DEV_BYPASS_IP_CHECK=true

# --- Service Role Key (NUNCA exponer en cliente) ---
# Necesaria para el panel /admin: salta RLS para leer datos de todos los usuarios.
# Sólo se usa desde route handlers server-side validados como admin.
# Panel Supabase > Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# --- Lista de emails con acceso al panel /admin ---
# Coma-separada. Sólo usuarios cuyo email esté en esta lista verán el botón
# "Panel admin" y podrán acceder a /admin y a /api/admin/*.
# Ejemplo: rrhh@acerca.info,direccion@acerca.info
ADMIN_EMAILS=
